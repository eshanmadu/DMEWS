PORT=4000
MONGODB_URI=
JWT_SECRET=
OPENWEATHER_API_KEY=
# https://www.weatherapi.com/ — preferred for /weather district details when set
WEATHERAPI_KEY=
ACCUWEATHER_API_KEY=
FIRECRAWL_API_KEY=

# Comma-separated emails that can access admin volunteer approval (must match login email).
ADMIN_EMAILS=you@example.com

# Local dev only: set to "true" so any logged-in user can approve volunteers (no ADMIN_EMAILS needed).
# Do not enable in production.
# ALLOW_VOLUNTEER_ADMIN_ANY_USER=true

# Cloudinary (for user incident media uploads: image/video)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=961357775579339
# CLOUDINARY_API_SECRET=

# Local dev: allow POST /auth/dev-admin-token so the login shortcut admin@admin.com / admin@123 gets a real JWT
# (needed for SOS admin, volunteer admin, etc.). Never enable in production.
# ALLOW_DEV_ADMIN_JWT=true
